jwt_refresh_secret     = ""

# Set after first deploy (use the App Runner URL)
domain_client = ""
domain_server = ""

sso_secret = ""

custom_domain = ""

google_client_id     = ""
google_client_secret = ""

stripe_price_id_plus      = ""
stripe_price_id_unlimited = ""
stripe_webhook_secret     = ""
stripe_secret_key         = ""

backboard_auth_assistant_id = ""
