{
  "name": "Nash",
  "version": "2.11.1",
  "description": "Nash 2.0 - Python backend with LibreChat UI",
  "private": true,
  "packageManager": "npm@11.10.0",
  "workspaces": [
    "client",
    "packages/*"
  ],
  "scripts": {
    "frontend": "npm run dev -w client",
    "build:packages": "npx turbo run build --filter=librechat-data-provider --filter=@librechat/data-schemas --filter=@librechat/client",
    "build:client": "npx turbo run build --filter=@librechat/frontend",
    "build": "npx turbo run build",
    "dev": "npm run frontend"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@react-hook/intersection-observer": "^3.1.2",
    "@stitches/core": "^1.2.8",
    "anser": "^2.3.5",
    "clean-set": "^1.1.2",
    "escape-carriage": "^1.3.1"
  }
}
